#include <iostream>
using namespace std;

#define MAX 20
int N;

// Function to print the board
void printSolution(int board[MAX][MAX]) {
    for (int i = 0; i < N; i++) {
        for (int j = 0; j < N; j++) {
            cout << board[i][j] << " ";
        }
        cout << endl;
    }
    cout << endl;
}

// Check if it's safe to place a queen
bool isSafe(int board[MAX][MAX], int row, int col) {

    // Check left side of row
    for (int i = 0; i < col; i++)
        if (board[row][i] == 1)
            return false;

    // Check upper diagonal
    for (int i = row, j = col; i >= 0 && j >= 0; i--, j--)
        if (board[i][j] == 1)
            return false;

    // Check lower diagonal
    for (int i = row, j = col; i < N && j >= 0; i++, j--)
        if (board[i][j] == 1)
            return false;

    return true;
}

// Backtracking function
bool solveNQ(int board[MAX][MAX], int col) {

    // Base case: all queens are placed
    if (col >= N) {
        printSolution(board);
        return true;
    }

    bool res = false;

    // Try placing queen in all rows
    for (int i = 0; i < N; i++) {
        if (isSafe(board, i, col)) {

            board[i][col] = 1;   // place queen

            res = solveNQ(board, col + 1) || res;

            board[i][col] = 0;   // backtrack
        }
    }
    return res;
}

int main() {
    int board[MAX][MAX] = {0};

    cout << "Enter number of queens: ";
    cin >> N;

    if (!solveNQ(board, 0)) {
        cout << "No solution exists" << endl;
    }

    return 0;
}
