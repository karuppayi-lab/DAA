#include<iostream>
#include<cmath>
using namespace std;
int main(){
   int n;
   cout<<"Enter no:of points:"<<endl;
   cin>>n;
   int x[100],y[100];
   cout<<"Enter coordinates:";
   for(int i=0;i<n;i++){
      cin>>x[i]>>y[i];
   }
   double mindist=999999.0;
   for(int i=0;i<n;i++){
      for(int j=i+1;j<n;j++){
         double dx=x[i]-x[j];
         double dy=y[i]-x[j];
         double dist=sqrt(dx*dx+dy*dy);
         if(dist<mindist){
            mindist=dist;
         }
      }
   }
   cout<<"closet distance:"<<mindist<<endl;
return 0;
}
