#include <iostream>
using namespace std;
const int MAX = 100;
const int INF = 1e9;
void floyd(int w[MAX][MAX], int n) {
    int dist[MAX][MAX];
    for (int i = 0; i<n; i++) {
        for (int j = 0; j<n; j++) {
            dist[i][j] = w[i][j];
        }
    }
    for (int k = 0; k<n; k++) {
        for (int i = 0; i<n; i++) {
            for (int j = 0; j<n; j++) {
                if (dist[i][k]<INF && dist[k][j] < INF &&
                    dist[i][k] + dist[k][j]< dist[i][j]) {
                    dist[i][j] = dist[i][k] + dist[k][j];
                }
            }
        }
   }
    cout << "Shortest distance matrix:\n";
    for (int i = 0; i<n; i++) {
        for (int j = 0; j<n; j++) {
            if (dist[i][j] == INF)
                cout<<"INF ";
            else
                cout<<dist[i][j]<< " ";
        }
        cout<<"\n";
    }
}
int main() {
    int n;
    int w[MAX][MAX];
    cout << "Enter number of vertices: ";
    cin >> n;
    cout <<"Enter the weight matrix :\n";
    for (int i = 0; i<n; i++) {
        for (int j = 0; j<n; j++) {
            cin >> w[i][j];
            if (w[i][j] == -1)
                w[i][j] = INF;
        }
    }
    floyd(w, n);
    return 0;
}
